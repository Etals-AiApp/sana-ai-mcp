{
  "name": "sana-mcp",
  "version": "0.1.0",
  "description": "Sync and read your Sana.AI meeting transcripts (CLI + MCP server)",
  "type": "module",
  "bin": {
    "sana": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "login": "tsx src/cli.ts login",
    "mcp": "tsx src/mcp.ts",
    "daemon": "tsx src/daemon-main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.10.0",
    "commander": "^12.1.0",
    "playwright": "^1.48.0",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/iarna__toml": "^2.0.5",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
